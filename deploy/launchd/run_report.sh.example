#!/bin/zsh
set -eu

APP_DIR="${APP_DIR:-$HOME/Library/Application Support/DailyBriefingBot/example_report}"
PROJECT_DIR="${PROJECT_DIR:-$HOME/src/daily-briefing-bot}"
PYTHON_BIN="${PYTHON_BIN:-python3}"
REPORT_NAME="${REPORT_NAME:-cctv}"
ENV_FILE="${ENV_FILE:-$APP_DIR/.env}"
LOG_DIR="$APP_DIR/logs"
mkdir -p "$LOG_DIR"
cd "$PROJECT_DIR"
REPORT_LOG="$LOG_DIR/report.log"

if [[ -f "$ENV_FILE" ]]; then
  set -a
  source "$ENV_FILE"
  set +a
fi

"$PYTHON_BIN" -m daily_briefing.cli run "$REPORT_NAME" --env "$ENV_FILE" >> "$REPORT_LOG" 2>&1
run_status=$?
if [[ "$run_status" -ne 0 ]]; then
  "$PYTHON_BIN" -m daily_briefing.cli alert "$REPORT_NAME" \
    --env "$ENV_FILE" \
    --message "launchd report command failed" \
    --exit-code "$run_status" \
    --log "$REPORT_LOG" \
    --push-targets primary >> "$LOG_DIR/alert.log" 2>&1 || true
fi
exit "$run_status"
