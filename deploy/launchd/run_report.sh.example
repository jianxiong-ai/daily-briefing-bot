#!/bin/zsh
set -eu

APP_DIR="${APP_DIR:-$HOME/Library/Application Support/DailyBriefingBot/example_report}"
PYTHON_BIN="${PYTHON_BIN:-python3}"
REPORT_SCRIPT="${REPORT_SCRIPT:-report.py}"
ENV_VAR_NAME="${ENV_VAR_NAME:-REPORT_ENV}"
ENV_FILE="${ENV_FILE:-$APP_DIR/.env}"
LOG_DIR="$APP_DIR/logs"
mkdir -p "$LOG_DIR"
cd "$APP_DIR"

if [[ -f "$ENV_FILE" ]]; then
  set -a
  source "$ENV_FILE"
  set +a
fi

export "$ENV_VAR_NAME=$ENV_FILE"
exec "$PYTHON_BIN" "$APP_DIR/$REPORT_SCRIPT" >> "$LOG_DIR/report.log" 2>&1
