API_CORS_ORIGINS="http://localhost:3010,http://127.0.0.1:3010,http://100.108.43.1:3010"
API_CORS_ORIGIN_REGEX="^http://(localhost|127\\.0\\.0\\.1|100\\.\\d+\\.\\d+\\.\\d+)(:3010)$"
# Leave empty to let the browser use the same host as the page with API port 8010.
NEXT_PUBLIC_API_BASE_URL=""

# Encrypts subscription secrets at rest in the dashboard database.
# Leave empty to auto-generate /data/secret.key in the Docker volume on first run.
DASHBOARD_SECRET_KEY=""

# Shared credentials used by generated subscription env files.
LLM_PROVIDER="deepseek"
DEEPSEEK_API_KEY="sk-your-deepseek-key"
DEEPSEEK_API_KEYS=""
DEEPSEEK_MODEL="deepseek-v4-pro"
LLM_TIMEOUT_SECONDS=270
REDFOX_API_KEY="ak_your-redfox-key"

# Optional Feishu image upload credentials.
FEISHU_APP_ID="cli_your-app-id"
FEISHU_APP_SECRET="your-app-secret"
FEISHU_IMAGE_DAILY_ENABLED=1
