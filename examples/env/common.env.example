# Common LLM settings
LLM_PROVIDER="deepseek"
DEEPSEEK_API_KEY="sk-your-deepseek-key"
DEEPSEEK_API_KEYS=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
LLM_TIMEOUT_SECONDS=270

# Push targets
PUSH_TARGETS="primary"
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook"
FEISHU_WEBHOOKS=""
WECHAT_WORK_WEBHOOK="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key"
WECHAT_WORK_WEBHOOKS=""

# Feishu image upload, optional
FEISHU_APP_ID="cli_xxx"
FEISHU_APP_SECRET="your-feishu-app-secret"
FEISHU_IMAGE_DAILY_ENABLED="1"

# Local test controls
SEND_AT_LOCAL=""
DIGEST_DATE=""
RENDER_ONLY="0"
RENDER_OUTPUT=""
