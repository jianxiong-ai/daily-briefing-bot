# Copy to work/wechat_daily/.env or set WECHAT_DAILY_ENV to this file.

REDFOX_API_KEY="ak_your-redfox-key"
WECHAT_DAILY_TITLE="昨日公众号信息汇总"
WECHAT_DAILY_KEYWORD=""
WECHAT_HOT_REPORT_LIMIT=10
WECHAT_HOT_CANDIDATE_LIMIT=50
WECHAT_MIN_READS=5000
WECHAT_MIN_HOT_ARTICLES=6
WECHAT_REQUIRE_FOLLOW_CONTENT=1
WECHAT_SOURCE_RETRY_ATTEMPTS=3
WECHAT_SOURCE_RETRY_DELAY_SECONDS=600
WECHAT_FOLLOW_AUTHORS="都市快报|dskbdskb;财联社|cls-telegraph;APPSO|appsolution;36氪|wow36kr;猫笔刀|maobidao"
WECHAT_FOLLOW_FETCH_WORKERS=4
WECHAT_FOLLOW_MAX_PAGES=2
WECHAT_DIGEST_OFFSET_DAYS=1

REDFOX_TIMEOUT_SECONDS=90
REDFOX_TODAY_CACHE_TTL_SECONDS=3600

# Include common.env.example values or source a shared env before running.
LLM_PROVIDER="deepseek"
DEEPSEEK_API_KEY="sk-your-deepseek-key"
PUSH_TARGETS="primary"
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook"
WECHAT_WORK_WEBHOOK=""
SEND_AT_LOCAL="08:00"
