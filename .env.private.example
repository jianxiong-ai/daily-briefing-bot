API_CORS_ORIGINS="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"

# Shared credentials used by generated subscription env files.
LLM_PROVIDER="deepseek"
DEEPSEEK_API_KEY="sk-your-deepseek-key"
DEEPSEEK_API_KEYS=""
DEEPSEEK_MODEL="deepseek-v4-pro"
LLM_TIMEOUT_SECONDS=270
REDFOX_API_KEY="ak_your-redfox-key"

# Optional Feishu image upload credentials.
FEISHU_APP_ID="cli_your-app-id"
FEISHU_APP_SECRET="your-app-secret"
FEISHU_IMAGE_DAILY_ENABLED=1
